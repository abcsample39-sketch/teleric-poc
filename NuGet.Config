<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <!-- Telerik NuGet Feed - requires authentication -->
    <!-- To configure: dotnet nuget add source https://nuget.telerik.com/v3/index.json -n Telerik -u
    <email> -p <api-key> -->
    <!-- Or set TELERIK_USERNAME and TELERIK_API_KEY environment variables -->
    <add key="telerik" value="https://nuget.telerik.com/v3/index.json" />
  </packageSources>
</configuration>